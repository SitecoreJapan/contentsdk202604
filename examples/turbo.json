{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "env": [
        "NODE_ENV",
        "EXPORT_MODE",
        "DISABLE_SSG_FETCH",
        "NEXT_PUBLIC_BUILD_ID",
        "NEXT_PUBLIC_COMMIT_REF",
        "FETCH_WITH",
        "JSS_APP_NAME",
        "GRAPH_QL_ENDPOINT",
        "GRAPH_QL_SERVICE_RETRIES",
        "SITECORE_API_HOST",
        "SITECORE_API_KEY",
        "SITECORE_EDGE_URL",
        "NEXT_PUBLIC_SITECORE_EDGE_URL",
        "SITECORE_SITE_NAME",
        "NEXT_PUBLIC_IMAGE_QUALITY",
        "NEXT_PUBLIC_ISR",
        "NEXT_REVALIDATION_TOKEN",
        "JSS_EDITING_SECRET",
        "DEFAULT_LANGUAGE",
        "SITECORE_EDGE_CONTEXT_ID",
        "NEXT_PUBLIC_SITECORE_EDGE_CONTEXT_ID",
        "NEXT_PUBLIC_DEFAULT_SITE_NAME",
        "SITECORE_EDITING_SECRET",
        "NEXT_PUBLIC_DEFAULT_LANGUAGE",
        "DEFAULT_SITE_NAME",
        "NEXT_PUBLIC_PERSONALIZE_SCOPE",
        "PERSONALIZE_MIDDLEWARE_CDP_TIMEOUT",
        "PERSONALIZE_MIDDLEWARE_EDGE_TIMEOUT",
        "SITECORE_AUTH_CLIENT_ID",
        "SITECORE_AUTH_CLIENT_SECRET"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "start": {
      "dependsOn": ["^build"],
      "env": [
        "NODE_ENV",
        "EXPORT_MODE",
        "DISABLE_SSG_FETCH",
        "NEXT_PUBLIC_BUILD_ID",
        "NEXT_PUBLIC_COMMIT_REF",
        "FETCH_WITH",
        "JSS_APP_NAME",
        "GRAPH_QL_ENDPOINT",
        "GRAPH_QL_SERVICE_RETRIES",
        "SITECORE_API_HOST",
        "SITECORE_API_KEY",
        "SITECORE_EDGE_URL",
        "NEXT_PUBLIC_SITECORE_EDGE_URL",
        "SITECORE_SITE_NAME",
        "SITECORE_EDGE_CONTEXT_ID",
        "NEXT_PUBLIC_IMAGE_QUALITY",
        "NEXT_PUBLIC_ISR",
        "NEXT_REVALIDATION_TOKEN",
        "JSS_EDITING_SECRET",
        "DEFAULT_LANGUAGE",
        "SITECORE_EDGE_CONTEXT_ID",
        "NEXT_PUBLIC_SITECORE_EDGE_CONTEXT_ID",
        "NEXT_PUBLIC_DEFAULT_SITE_NAME",
        "SITECORE_EDITING_SECRET",
        "NEXT_PUBLIC_DEFAULT_LANGUAGE",
        "DEFAULT_SITE_NAME",
        "NEXT_PUBLIC_PERSONALIZE_SCOPE",
        "PERSONALIZE_MIDDLEWARE_CDP_TIMEOUT",
        "PERSONALIZE_MIDDLEWARE_EDGE_TIMEOUT",
        "SITECORE_AUTH_CLIENT_ID",
        "SITECORE_AUTH_CLIENT_SECRET"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
